# Environment Variables Template
# Copy this file to .env and configure for your environment

# API Configuration
VITE_API_BASE_URL=/api/v1

# Azure Entra ID (MSAL) Configuration
VITE_AZURE_CLIENT_ID=
VITE_AZURE_TENANT_ID=common
VITE_AZURE_REDIRECT_URI=http://localhost:5173

# MSAL Scopes
VITE_AZURE_API_SCOPE=api://default/access_as_user

# Auth Bypass (for local development without Azure)
# Set to 'true' to bypass MSAL authentication
VITE_AUTH_BYPASS=false

# OpenTelemetry Collector URL (for browser tracing)
# Default: /otel (proxied through nginx to otel-collector:4318)
VITE_OTEL_COLLECTOR_URL=/otel

# FS27 – Live Excel Export & External Sync
# Set to 'false' to hide the Export Flows UI section
VITE_EXPORT_FLOWS_ENABLED=true
