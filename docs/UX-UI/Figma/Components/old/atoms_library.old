<svg width="1000" height="800" viewBox="0 0 1000 800" xmlns="http://www.w3.org/2000/svg">
  <!-- CIM Design System - Atoms Library -->
  <rect width="1000" height="800" fill="#F8F8F8"/>
  
  <text x="40" y="50" font-family="Inter, sans-serif" font-size="24" font-weight="bold" fill="#242424">01 — Atoms Library</text>
  
  <!-- Buttons Section -->
  <text x="40" y="100" font-family="Inter, sans-serif" font-size="18" font-weight="600" fill="#616161">1.1 Buttons</text>
  
  <!-- Primary Button -->
  <rect x="40" y="130" width="140" height="32" rx="8" fill="#0078D4"/>
  <text x="65" y="151" font-family="Inter, sans-serif" font-size="14" fill="#FFFFFF">Primary Action</text>
  <text x="40" y="175" font-family="Inter, sans-serif" font-size="10" fill="#9E9E9E">Primary (Brand90)</text>
  
  <!-- Outline Button -->
  <rect x="200" y="130" width="140" height="32" rx="8" fill="none" stroke="#E1DFDD" stroke-width="1"/>
  <text x="235" y="151" font-family="Inter, sans-serif" font-size="14" fill="#242424">Secondary</text>
  <text x="200" y="175" font-family="Inter, sans-serif" font-size="10" fill="#9E9E9E">Outline (Stroke1)</text>
  
  <!-- Subtle Button -->
  <rect x="360" y="130" width="100" height="32" rx="8" fill="#F3F2F1"/>
  <text x="390" y="151" font-family="Inter, sans-serif" font-size="14" fill="#616161">Subtle</text>
  
  <!-- Status Badges Section -->
  <text x="40" y="240" font-family="Inter, sans-serif" font-size="18" font-weight="600" fill="#616161">1.2 Status Badges</text>
  
  <rect x="40" y="260" width="100" height="24" rx="12" fill="#DFF6DD"/>
  <circle cx="55" cy="272" r="4" fill="#107C10"/>
  <text x="65" y="277" font-family="Inter, sans-serif" font-size="12" fill="#107C10">Success</text>
  
  <rect x="150" y="260" width="100" height="24" rx="12" fill="#FDE7E9"/>
  <circle cx="165" cy="272" r="4" fill="#D13438"/>
  <text x="175" y="277" font-family="Inter, sans-serif" font-size="12" fill="#D13438">Danger</text>
  
  <rect x="260" y="260" width="100" height="24" rx="12" fill="#FDEBE2"/>
  <circle cx="275" cy="272" r="4" fill="#D83B01"/>
  <text x="285" y="277" font-family="Inter, sans-serif" font-size="12" fill="#D83B01">Warning</text>
  
  <!-- Infrastructure Icons -->
  <text x="40" y="340" font-family="Inter, sans-serif" font-size="18" font-weight="600" fill="#616161">1.3 Core Icons (24px)</text>
  
  <!-- Server Icon -->
  <g transform="translate(40, 360)">
    <rect x="2" y="4" width="20" height="6" rx="1" fill="none" stroke="#0078D4" stroke-width="1.5"/>
    <rect x="2" y="14" width="20" height="6" rx="1" fill="none" stroke="#0078D4" stroke-width="1.5"/>
    <circle cx="6" cy="7" r="1" fill="#0078D4"/>
    <circle cx="6" cy="17" r="1" fill="#0078D4"/>
  </g>
  <text x="40" y="400" font-family="Inter, sans-serif" font-size="10" fill="#9E9E9E">Server</text>
  
  <!-- Database Icon -->
  <g transform="translate(100, 360)">
    <ellipse cx="12" cy="6" rx="8" ry="3" fill="none" stroke="#0078D4" stroke-width="1.5"/>
    <path d="M4 6V18C4 19.6569 7.58172 21 12 21C16.4183 21 20 19.6569 20 18V6" fill="none" stroke="#0078D4" stroke-width="1.5"/>
    <path d="M4 12C4 13.6569 7.58172 15 12 15C16.4183 15 20 13.6569 20 12" fill="none" stroke="#0078D4" stroke-width="1.5"/>
  </g>
  <text x="100" y="400" font-family="Inter, sans-serif" font-size="10" fill="#9E9E9E">Database</text>
  
  <!-- Cloud Icon -->
  <g transform="translate(160, 360)">
    <path d="M17.5 19C20.5376 19 23 16.5376 23 13.5C23 10.4624 20.5376 8 17.5 8C17.3884 8 17.2783 8.00331 17.1695 8.00984C16.1422 4.49983 12.8716 2 9 2C4.58172 2 1 5.58172 1 10C1 10.1585 1.0046 10.3159 1.01358 10.4718C0.400589 11.2373 0.0351562 12.1963 0.0351562 13.2383C0.0351562 15.61 1.95834 17.5332 4.33123 17.5332C4.56947 17.5332 4.80164 17.514 5.02715 17.4771C6.20845 18.4116 7.69614 18.9668 9.31641 18.9668H17.5Z" fill="none" stroke="#0078D4" stroke-width="1.5"/>
  </g>
  <text x="160" y="400" font-family="Inter, sans-serif" font-size="10" fill="#9E9E9E">Cloud</text>
</svg>
