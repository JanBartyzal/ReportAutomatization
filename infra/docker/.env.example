# =============================================================================
# ReportAutomatization P8 - Environment Variables Template (Consolidated)
# =============================================================================
# Copy this file to .env and configure for your environment
# Usage: cp .env.example .env
#
# This file reflects the P8 consolidated microservices architecture:
# - 8 deployment units instead of 29 individual services
# - Simplified port allocation
# - Shared database credentials per unit

# =============================================================================
# CONSOLIDATED SERVICE PORTS
# =============================================================================

# Java Service Ports (HTTP)
ENGINE_CORE_PORT=8081
ENGINE_INGESTOR_PORT=8082
ENGINE_ORCHESTRATOR_PORT=8083
ENGINE_SCAN_PORT=8084
ENGINE_DATA_PORT=8100
ENGINE_REPORTING_PORT=8105
ENGINE_INTEGRATIONS_PORT=8107

# Python Processor Ports
PROCESSOR_ATOMIZERS_PORT=8088
PROCESSOR_GENERATORS_PORT=8111

# gRPC Ports
ENGINE_ORCHESTRATOR_GRPC=50051
ENGINE_DATA_GRPC=50052
PROCESSOR_ATOMIZERS_GRPC=50090
PROCESSOR_GENERATORS_GRPC=50091

# Infrastructure Ports
NGINX_PORT=80
NGINX_SSL_PORT=443
POSTGRES_PORT=5432
REDIS_PORT=6379
AZURITE_PORT=10000
CLAMAV_PORT=3310
DAPR_PORT=3500

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=reportplatform
DB_HOST=postgres
DB_PORT=5432

# Consolidated Unit Databases (8 databases instead of 20+)
# Each unit has its own database for isolation
ENGINE_CORE_DB=engine_core_db
ENGINE_CORE_DB_USER=engine_core_user
ENGINE_CORE_DB_PASS=engine_core_pass

ENGINE_INGESTOR_DB=engine_ingestor_db
ENGINE_INGESTOR_DB_USER=engine_ingestor_user
ENGINE_INGESTOR_DB_PASS=engine_ingestor_pass

ENGINE_ORCHESTRATOR_DB=engine_orchestrator_db
ENGINE_ORCHESTRATOR_DB_USER=engine_orchestrator_user
ENGINE_ORCHESTRATOR_DB_PASS=engine_orchestrator_pass

ENGINE_DATA_DB=engine_data_db
ENGINE_DATA_DB_USER=engine_data_user
ENGINE_DATA_DB_PASS=engine_data_pass

ENGINE_REPORTING_DB=engine_reporting_db
ENGINE_REPORTING_DB_USER=engine_reporting_user
ENGINE_REPORTING_DB_PASS=engine_reporting_pass

ENGINE_INTEGRATIONS_DB=engine_integrations_db
ENGINE_INTEGRATIONS_DB_USER=engine_integrations_user
ENGINE_INTEGRATIONS_DB_PASS=engine_integrations_pass

# Legacy database variables (for backward compatibility during migration)
AUTH_DB=auth_db
AUTH_DB_USER=auth_user
AUTH_DB_PASS=auth_pass

MS_ING_DB=ms_ing
MS_ING_DB_USER=ms_ing
MS_ING_DB_PASS=ms_ing_pass

# =============================================================================
# REDIS CONFIGURATION (Shared across all services)
# =============================================================================

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_pass

# =============================================================================
# AZURE BLOB STORAGE (AZURITE FOR LOCAL DEV)
# =============================================================================

# Azurite connection string for local development
# Default account: devstoreaccount1
# Default key: Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;BlobEndpoint=http://azurite:10000/devstoreaccount1
AZURE_STORAGE_CONTAINER=file-uploads
AZURE_TEMP_CONTAINER=temp
AZURE_TEMPLATES_CONTAINER=templates
AZURE_GENERATED_CONTAINER=generated-reports

# =============================================================================
# AZURE ENTRA ID (AAD) CONFIGURATION
# =============================================================================

AZURE_TENANT_ID=common
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_KEYVAULT_URI=
AZURE_KEYVAULT_ENABLED=false
AZURE_REDIRECT_URI=http://localhost

# JWT Configuration (used by engine-core for token validation)
JWT_ISSUER=https://login.microsoftonline.com/common/v2.0
JWT_AUDIENCE=
JWT_JWKS_URI=https://login.microsoftonline.com/common/discovery/v2.0/keys

# =============================================================================
# CLAMAV CONFIGURATION
# =============================================================================

CLAMAV_HOST=clamav
CLAMAV_PORT=3310

# =============================================================================
# DAPR CONFIGURATION (Service Mesh)
# =============================================================================

DAPR_HOST=localhost
DAPR_HTTP_PORT=3500
DAPR_GRPC_PORT=50001
DAPR_PUBSUB_NAME=reportplatform-pubsub
DAPR_STATESTORE_NAME=reportplatform-statestore

# =============================================================================
# LITE LLM CONFIGURATION (AI Gateway)
# =============================================================================

LITELLM_BASE_URL=http://litellm:4000
LITELLM_API_KEY=sk-local-dev-key

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================

API_URL=http://localhost

# =============================================================================
# LOGGING
# =============================================================================

LOG_LEVEL=INFO

# =============================================================================
# N8N (Optional - for workflow automation)
# =============================================================================

N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=admin
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_SECURE_COOKIE=false
WEBHOOK_URL=http://localhost:5678

# =============================================================================
# PGADMIN (Optional - for database management)
# =============================================================================

PGADMIN_DEFAULT_EMAIL=admin@reportplatform.local
PGADMIN_DEFAULT_PASSWORD=admin

# =============================================================================
# SERVICE-NOW INTEGRATION (P7)
# =============================================================================

# ServiceNow Connector Configuration (now part of engine-integrations)
SERVICENOW_INSTANCE_URL=
SERVICENOW_AUTH_TYPE=oauth2  # or 'basic'
SERVICENOW_CLIENT_ID=
SERVICENOW_CLIENT_SECRET=
SERVICENOW_USERNAME=
SERVICENOW_PASSWORD=

# =============================================================================
# PYTHON PROCESSOR CONFIGURATION
# =============================================================================

# Processor Atomizers
PROCESSOR_ATOMIZERS_HTTP_PORT=8088
PROCESSOR_ATOMIZERS_GRPC_PORT=50090
DEFAULT_MONTHLY_TOKEN_QUOTA=1000000
MAX_CONCURRENT_PER_ORG=5
CLEANUP_INTERVAL_HOURS=6
CLEANUP_DRY_RUN=false

# Processor Generators
PROCESSOR_GENERATORS_HTTP_PORT=8111
PROCESSOR_GENERATORS_GRPC_PORT=50091

# =============================================================================
# OBSERVABILITY (Optional)
# =============================================================================

# OpenTelemetry Collector
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=http://otel-collector:4317

# =============================================================================
# LEGACY SERVICE MAPPING (for backward compatibility during migration)
# =============================================================================
# The following mappings show which old services are now part of consolidated units:
#
# engine-core (port 8081): ms-auth, ms-admin, ms-batch, ms-ver, ms-audit
# engine-ingestor (port 8082): ms-ing
# engine-orchestrator (port 8083): ms-orch
# engine-data (port 8100): ms-sink-tbl, ms-sink-doc, ms-sink-log, ms-qry, ms-dash, ms-srch, ms-tmpl
# engine-reporting (port 8105): ms-lifecycle, ms-period, ms-form, ms-tmpl-pptx, ms-notif
# engine-integrations (port 8107): ms-ext-snow
# processor-atomizers (port 8088): ms-atm-pptx, ms-atm-xls, ms-atm-pdf, ms-atm-csv, ms-atm-ai, ms-atm-cln
# processor-generators (port 8111): ms-gen-pptx, ms-gen-xls, ms-mcp
