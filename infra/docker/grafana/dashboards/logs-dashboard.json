{
  "uid": "reportplatform-logs",
  "title": "ReportPlatform - Logs",
  "tags": ["reportplatform", "logs"],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "label": "Service",
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "query": "label_values(service_name)",
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "refresh": 2
      },
      {
        "name": "level",
        "type": "custom",
        "label": "Level",
        "query": ",ERROR,WARN,INFO,DEBUG",
        "multi": false,
        "includeAll": true,
        "allValue": "",
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "options": [
          { "text": "All", "value": "$__all", "selected": false },
          { "text": "", "value": "", "selected": false },
          { "text": "ERROR", "value": "ERROR", "selected": false },
          { "text": "WARN", "value": "WARN", "selected": false },
          { "text": "INFO", "value": "INFO", "selected": false },
          { "text": "DEBUG", "value": "DEBUG", "selected": false }
        ]
      },
      {
        "name": "search",
        "type": "textbox",
        "label": "Search Text",
        "current": {
          "selected": false,
          "text": "",
          "value": ""
        }
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Volume",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "type": "barchart",
      "title": "Log Volume by Service",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 1 },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service_name) (count_over_time({service_name=~\"$service\"} |~ \"$search\" [1m]))",
          "legendFormat": "{{service_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 80,
            "gradientMode": "scheme",
            "stacking": {
              "mode": "normal"
            }
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "barWidth": 0.9,
        "groupWidth": 0.7,
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" },
        "xTickLabelRotation": 0,
        "stacking": "normal"
      }
    },
    {
      "type": "row",
      "title": "Log Explorer",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "collapsed": false
    },
    {
      "type": "logs",
      "title": "Log Stream",
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 8 },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{service_name=~\"$service\"} | json | level=~\"$level\" |~ \"$search\""
        }
      ],
      "options": {
        "showLabels": true,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "showTime": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "type": "row",
      "title": "Error Analysis",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Error Rate by Service",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 23 },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service_name) (count_over_time({service_name=~\"$service\"} | json | level=\"ERROR\" [5m]))",
          "legendFormat": "{{service_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2,
            "spanNulls": false
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom" }
      }
    },
    {
      "type": "stat",
      "title": "Error Logs Count",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 23 },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({service_name=~\"$service\"} | json | level=\"ERROR\" [$__range]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 100 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "type": "row",
      "title": "Correlation",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 29 },
      "collapsed": false
    },
    {
      "type": "logs",
      "title": "Trace Correlation",
      "description": "Logs with trace IDs - click the TraceID link to jump to Tempo trace view",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 30 },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{service_name=~\"$service\"} | json | trace_id != \"\""
        }
      ],
      "options": {
        "showLabels": true,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "showTime": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    }
  ]
}