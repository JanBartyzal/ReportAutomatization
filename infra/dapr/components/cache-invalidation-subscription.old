# TASK-WG-CACHE-001: Dapr PubSub subscriptions for cache invalidation events.
# Routes events from various units to unit-cache-invalidator endpoints.
---
apiVersion: dapr.io/v1alpha1
kind: Subscription
metadata:
  name: cache-invalidation-plan-created
spec:
  pubsubname: pubsub
  topic: plan.created
  route: /events/plan-created
  scopes:
    - unit-cache-invalidator
---
apiVersion: dapr.io/v1alpha1
kind: Subscription
metadata:
  name: cache-invalidation-plan-updated
spec:
  pubsubname: pubsub
  topic: plan.updated
  route: /events/plan-updated
  scopes:
    - unit-cache-invalidator
---
apiVersion: dapr.io/v1alpha1
kind: Subscription
metadata:
  name: cache-invalidation-approval
spec:
  pubsubname: pubsub
  topic: approval.action
  route: /events/approval-action
  scopes:
    - unit-cache-invalidator
---
apiVersion: dapr.io/v1alpha1
kind: Subscription
metadata:
  name: cache-invalidation-cost
spec:
  pubsubname: pubsub
  topic: cost.recalculated
  route: /events/cost-recalculated
  scopes:
    - unit-cache-invalidator
---
apiVersion: dapr.io/v1alpha1
kind: Subscription
metadata:
  name: cache-invalidation-policy
spec:
  pubsubname: pubsub
  topic: policy.changed
  route: /events/policy-changed
  scopes:
    - unit-cache-invalidator
---
apiVersion: dapr.io/v1alpha1
kind: Subscription
metadata:
  name: cache-invalidation-billing
spec:
  pubsubname: pubsub
  topic: billing.synced
  route: /events/billing-synced
  scopes:
    - unit-cache-invalidator
