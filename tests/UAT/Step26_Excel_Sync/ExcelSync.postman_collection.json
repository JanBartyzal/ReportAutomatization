{
  "info": {
    "name": "RA – Excel Sync (FS27)",
    "description": "Export Flow CRUD and execution endpoints for the Live Excel Export & External Sync feature (FS27). Base URL: {{baseUrl}}",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "ra-excel-sync-v1"
  },
  "variable": [
    { "key": "baseUrl",    "value": "http://localhost" },
    { "key": "orgId",      "value": "00000000-0000-0000-0000-000000000001" },
    { "key": "userId",     "value": "test-user" },
    { "key": "flowId",     "value": "11111111-0000-0000-0000-000000000001" },
    { "key": "executionId","value": "" }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/export-flows/health",
        "description": "Returns module status (UP/DOWN) for local path and SharePoint connectors."
      },
      "response": [
        {
          "name": "200 UP",
          "status": "OK",
          "code": 200,
          "_postman_previewlanguage": "json",
          "body": "{\n  \"status\": \"UP\",\n  \"localPath\": \"UP\",\n  \"sharepoint\": \"UNKNOWN\"\n}"
        }
      ]
    },
    {
      "name": "List Export Flows",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/export-flows",
        "header": [
          { "key": "X-Org-Id",  "value": "{{orgId}}" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "description": "Returns all export flow definitions for the authenticated organisation."
      },
      "response": [
        {
          "name": "200 List",
          "status": "OK",
          "code": 200,
          "_postman_previewlanguage": "json",
          "body": "[\n  {\n    \"id\": \"11111111-0000-0000-0000-000000000001\",\n    \"name\": \"OPEX Monthly Report\",\n    \"targetType\": \"LOCAL_PATH\",\n    \"isActive\": true\n  }\n]"
        }
      ]
    },
    {
      "name": "Get Export Flow",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/export-flows/{{flowId}}",
        "header": [
          { "key": "X-Org-Id",      "value": "{{orgId}}" },
          { "key": "Authorization",  "value": "Bearer {{accessToken}}" }
        ],
        "description": "Returns a single export flow definition by ID."
      },
      "response": []
    },
    {
      "name": "Create Export Flow",
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/api/export-flows",
        "header": [
          { "key": "X-Org-Id",      "value": "{{orgId}}" },
          { "key": "X-User-Id",     "value": "{{userId}}" },
          { "key": "Authorization",  "value": "Bearer {{accessToken}}" },
          { "key": "Content-Type",   "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"OPEX Monthly – Local\",\n  \"description\": \"Monthly OPEX export to network share\",\n  \"sqlQuery\": \"SELECT department, SUM(amount) AS total FROM opex WHERE period = '2026-04' GROUP BY department\",\n  \"targetType\": \"LOCAL_PATH\",\n  \"targetPath\": \"/mnt/exports/opex\",\n  \"targetSheet\": \"OPEX_Data\",\n  \"fileNaming\": \"CUSTOM\",\n  \"customFileName\": \"opex_2026_04.xlsx\",\n  \"triggerType\": \"AUTO\",\n  \"triggerFilter\": {\"batchType\": \"OPEX\"}\n}"
        },
        "description": "Creates a new export flow definition."
      },
      "response": [
        {
          "name": "201 Created",
          "status": "Created",
          "code": 201,
          "_postman_previewlanguage": "json",
          "body": "{\n  \"id\": \"<new-uuid>\",\n  \"name\": \"OPEX Monthly – Local\",\n  \"targetType\": \"LOCAL_PATH\",\n  \"isActive\": true\n}"
        }
      ],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 201) {",
              "  var body = pm.response.json();",
              "  pm.collectionVariables.set('flowId', body.id);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Update Export Flow",
      "request": {
        "method": "PUT",
        "url": "{{baseUrl}}/api/export-flows/{{flowId}}",
        "header": [
          { "key": "X-Org-Id",      "value": "{{orgId}}" },
          { "key": "Authorization",  "value": "Bearer {{accessToken}}" },
          { "key": "Content-Type",   "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"description\": \"Updated description\",\n  \"isActive\": true\n}"
        },
        "description": "Partially updates an existing export flow definition."
      },
      "response": []
    },
    {
      "name": "Delete Export Flow",
      "request": {
        "method": "DELETE",
        "url": "{{baseUrl}}/api/export-flows/{{flowId}}",
        "header": [
          { "key": "X-Org-Id",     "value": "{{orgId}}" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "description": "Soft-deletes an export flow (sets is_active=false)."
      },
      "response": []
    },
    {
      "name": "Execute Export Flow (Manual Trigger)",
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/api/export-flows/{{flowId}}/execute",
        "header": [
          { "key": "X-Org-Id",     "value": "{{orgId}}" },
          { "key": "X-User-Id",    "value": "{{userId}}" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "description": "Manually triggers an export flow execution. Returns execution ID and PENDING status."
      },
      "response": [
        {
          "name": "202 Accepted",
          "status": "Accepted",
          "code": 202,
          "_postman_previewlanguage": "json",
          "body": "{\n  \"executionId\": \"<execution-uuid>\",\n  \"flowId\": \"{{flowId}}\",\n  \"status\": \"PENDING\"\n}"
        }
      ],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 202) {",
              "  var body = pm.response.json();",
              "  pm.collectionVariables.set('executionId', body.executionId);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Execution History",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/export-flows/{{flowId}}/executions?page=0&size=20",
          "host": ["{{baseUrl}}"],
          "path": ["api", "export-flows", "{{flowId}}", "executions"],
          "query": [
            { "key": "page", "value": "0" },
            { "key": "size", "value": "20" }
          ]
        },
        "header": [
          { "key": "X-Org-Id",     "value": "{{orgId}}" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "description": "Returns paginated execution history for the given flow (sorted by started_at DESC)."
      },
      "response": []
    },
    {
      "name": "Test Export Flow (Dry Run)",
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/api/export-flows/{{flowId}}/test",
        "header": [
          { "key": "X-Org-Id",     "value": "{{orgId}}" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "description": "Executes the SQL query and returns a preview of the rows that would be exported (no file written)."
      },
      "response": [
        {
          "name": "200 Preview",
          "status": "OK",
          "code": 200,
          "_postman_previewlanguage": "json",
          "body": "{\n  \"flowId\": \"{{flowId}}\",\n  \"rowCount\": 25,\n  \"columns\": [\"department\", \"total\"],\n  \"previewRows\": [\n    {\"department\": \"IT\", \"total\": 45000.00}\n  ],\n  \"error\": null\n}"
        }
      ]
    }
  ]
}
